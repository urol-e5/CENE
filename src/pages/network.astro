---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base title="Network Explorer" active="/network" description="Interactive multilayer regulatory network of predicted miRNA, lncRNA, mRNA, and epigenetic-machinery interactions in three corals.">
  <div class="container-wide" style="padding-top:1rem;">
    <div class="flex between" style="align-items:flex-end;">
      <div>
        <h1 style="margin:0;">Network Explorer</h1>
        <p class="muted" style="margin:0.2rem 0;">Predicted multilayer regulatory network. A focused subnetwork loads by default — apply filters or presets to explore.</p>
      </div>
      <span class="pill no-print">All edges are <strong style="margin:0 .25rem;">predicted</strong> · correlation ≠ causation</span>
    </div>

    <div class="net-layout">
      <!-- Controls -->
      <aside class="net-controls card no-print" aria-label="Network filters">
        <div class="flex between"><strong>Filters</strong><button id="resetFilters" class="btn btn-outline btn-sm">Reset</button></div>

        <div class="presets">
          <span class="small muted">Presets</span>
          <div class="flex" style="gap:0.35rem;">
            <button class="btn btn-sm chip" data-preset="epimirna">Epi-miRNAs</button>
            <button class="btn btn-sm chip" data-preset="cerna">ceRNA networks</button>
            <button class="btn btn-sm chip" data-preset="lncmrna">lncRNA–mRNA coexpression</button>
            <button class="btn btn-sm chip" data-preset="conserved">Conserved miRNAs</button>
            <button class="btn btn-sm chip" data-preset="mir100">miR-100</button>
            <button class="btn btn-sm chip" data-preset="dnameth">DNA-methylation machinery</button>
            <button class="btn btn-sm chip" data-preset="ncrna">ncRNA-biogenesis machinery</button>
            <button class="btn btn-sm chip" data-preset="negative">Negatively coexpressed</button>
          </div>
        </div>

        <label class="control">Species
          <select id="fSpecies">
            <option value="Apul">Acropora pulchra</option>
            <option value="Peve">Porites evermanni</option>
            <option value="Ptuh">Pocillopora tuahiniensis</option>
          </select>
        </label>

        <label class="control">Seed miRNA / transcript (focus neighbourhood)
          <input type="search" id="fSearch" list="nodeList" placeholder="e.g. apul-mir-100, FUN_043573, TNRC6" autocomplete="off" />
          <datalist id="nodeList"></datalist>
        </label>

        <label class="control">miRNA
          <select id="fMiRNA"><option value="">All miRNAs</option></select>
        </label>

        <fieldset class="fs">
          <legend>Interaction type</legend>
          <label class="checkbox"><input type="checkbox" class="fClass" value="miRNA-mRNA" checked /> miRNA–mRNA</label>
          <label class="checkbox"><input type="checkbox" class="fClass" value="miRNA-lncRNA" checked /> miRNA–lncRNA</label>
          <label class="checkbox"><input type="checkbox" class="fClass" value="lncRNA-mRNA" checked /> lncRNA–mRNA coexpression</label>
        </fieldset>

        <fieldset class="fs">
          <legend>Binding region (miRNA edges)</legend>
          <label class="checkbox"><input type="checkbox" class="fRegion" value="CDS" checked /> CDS</label>
          <label class="checkbox"><input type="checkbox" class="fRegion" value="5UTR" checked /> 5′UTR</label>
          <label class="checkbox"><input type="checkbox" class="fRegion" value="3UTR" checked /> 3′UTR</label>
          <label class="checkbox"><input type="checkbox" class="fRegion" value="lncRNA" checked /> lncRNA</label>
        </fieldset>

        <fieldset class="fs">
          <legend>Correlation direction</legend>
          <label class="checkbox"><input type="radio" name="dir" class="fDir" value="all" checked /> All</label>
          <label class="checkbox"><input type="radio" name="dir" class="fDir" value="positive" /> Positive</label>
          <label class="checkbox"><input type="radio" name="dir" class="fDir" value="negative" /> Negative</label>
        </fieldset>

        <label class="control">Minimum |Pearson r| — <span id="pccVal">0.88</span>
          <input type="range" id="fPcc" min="0.80" max="1" step="0.01" value="0.88" />
        </label>
        <label class="control">Maximum p-value — <span id="pVal">0.05</span>
          <input type="range" id="fP" min="0.01" max="0.05" step="0.005" value="0.05" />
        </label>

        <label class="control">Epigenetic-machinery category
          <select id="fEpiCat"><option value="">Any</option></select>
        </label>

        <div class="stack">
          <label class="checkbox"><input type="checkbox" id="fEpiOnly" /> Epi-miRNA interactions only</label>
          <label class="checkbox"><input type="checkbox" id="fCeOnly" /> ceRNA interactions only</label>
          <label class="checkbox"><input type="checkbox" id="fConservedOnly" /> Conserved miRNAs only</label>
          <label class="checkbox"><input type="checkbox" id="fHideIso" checked /> Hide isolated nodes</label>
        </div>

        <label class="control">Max nodes rendered — <span id="capVal">400</span>
          <input type="range" id="fCap" min="100" max="1200" step="100" value="400" />
        </label>

        <button id="applyBtn" class="btn" style="width:100%;">Apply filters</button>
      </aside>

      <!-- Graph -->
      <section class="net-main">
        <div class="net-toolbar no-print">
          <div class="flex" style="gap:0.3rem; align-items:center;">
            <label class="net-layout-pick" title="Graph layout style">
              <span class="small muted">Layout</span>
              <select id="fLayout" class="btn-sm">
                <option value="concentric">Concentric (miRNA-centred)</option>
                <option value="cose">Force-directed</option>
                <option value="breadthfirst">Hierarchical</option>
                <option value="circle">Circle</option>
                <option value="grid">Grid</option>
              </select>
            </label>
            <button class="btn btn-outline btn-sm" id="btnFit" title="Fit to view">⤢ Fit</button>
            <button class="btn btn-outline btn-sm" id="btnReset" title="Reset view">↺ Reset</button>
            <button class="btn btn-outline btn-sm" id="btnExpand" title="Expand neighbourhood of selection" disabled>＋ Expand</button>
          </div>
          <div class="flex" style="gap:0.3rem; margin-left:auto;">
            <button class="btn btn-outline btn-sm" id="btnPng">PNG</button>
            <button class="btn btn-outline btn-sm" id="btnSvg">SVG</button>
            <button class="btn btn-outline btn-sm" id="btnCsv">CSV</button>
            <button class="btn btn-outline btn-sm" id="btnShare">Share link</button>
          </div>
        </div>
        <div id="cy" role="application" aria-label="Interactive network graph"></div>
        <div id="netStatus" class="net-status" aria-live="polite"></div>
        <div id="netLegend" class="net-legend"></div>
      </section>

      <!-- Detail panel -->
      <aside id="detail" class="net-detail card" aria-live="polite">
        <p class="muted small">Click a node or edge to inspect its details and supporting evidence.</p>
      </aside>
    </div>
  </div>
</Base>

<style>
  .net-layout { display: grid; grid-template-columns: 280px 1fr 320px; gap: 1rem; margin: 1rem 0 2rem; align-items: start; }
  .net-controls { position: sticky; top: 72px; max-height: calc(100vh - 88px); overflow-y: auto; display: flex; flex-direction: column; gap: 0.7rem; }
  .net-controls .fs { border: 1px solid var(--line); border-radius: 8px; padding: 0.5rem 0.7rem; margin: 0; display: flex; flex-direction: column; gap: 0.2rem; }
  .net-controls legend { font-size: 0.78rem; font-weight: 700; color: var(--muted); padding: 0 0.3rem; }
  .presets { display: flex; flex-direction: column; gap: 0.3rem; }
  .chip { background: var(--surface); color: var(--sea); border: 1px solid var(--line); }
  .chip:hover, .chip[aria-pressed="true"] { background: var(--sea); color: #fff; }
  .net-main { min-width: 0; }
  .net-toolbar { display: flex; gap: 0.4rem; margin-bottom: 0.5rem; align-items: center; flex-wrap: wrap; }
  .net-layout-pick { display: inline-flex; align-items: center; gap: 0.3rem; }
  .net-layout-pick select { padding: 0.25rem 0.4rem; border: 1px solid var(--line); border-radius: 6px; background: var(--surface); color: var(--ink); font-size: 0.82rem; }
  #cy { width: 100%; height: 620px; background:
      radial-gradient(circle at 30% 20%, color-mix(in srgb, var(--sea) 8%, var(--paper)), var(--paper));
      border: 1px solid var(--line); border-radius: var(--radius); }
  .net-status { font-size: 0.82rem; color: var(--muted); margin-top: 0.4rem; min-height: 1.2rem; }
  .net-legend { margin-top: 0.6rem; }
  .net-detail { position: sticky; top: 72px; max-height: calc(100vh - 88px); overflow-y: auto; }
  .dl { display: grid; grid-template-columns: auto 1fr; gap: 0.15rem 0.6rem; font-size: 0.84rem; margin: 0.4rem 0; }
  .dl dt { color: var(--muted); font-weight: 600; }
  .dl dd { margin: 0; word-break: break-word; }
  @media (max-width: 1180px) {
    .net-layout { grid-template-columns: 1fr; }
    .net-controls, .net-detail { position: static; max-height: none; }
    #cy { height: 500px; }
  }
</style>

<script src="../scripts/network.ts"></script>
